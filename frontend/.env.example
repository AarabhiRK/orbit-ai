# Must match where the Express API listens. Backend defaults to port 5050.
# VITE_API_URL=http://localhost:5051

# Supabase (browser auth + same project as backend). Dashboard → Project Settings → API:
# Copy "Project URL" and the anon public key.
# Create a local file frontend/.env.development.local with the real values (gitignored).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here
