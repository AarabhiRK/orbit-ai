# Optional. Default in server.js is 5050 (avoids macOS AirPlay on 5000).
# PORT=5050

# Required for /generate-next-action and /generate-schedule (narrative layer always calls Gemini).
# Create a key at https://aistudio.google.com/apikey — put the real value only in backend/.env, never commit it.
GEMINI_API_KEY=

# Optional: force one Gemini model id first (e.g. gemini-2.5-flash). If unset, ORBIT tries 2.5-flash, 1.5-flash, then 2.0-flash.
# Setting GEMINI_MODEL=gemini-2.0-flash still tries newer models first — 2.0-flash is last (free tier often exhausts it).
# GEMINI_MODEL=gemini-2.5-flash

# Optional: max wait for Gemini narrative (ms). On timeout the request fails with 502 (no silent fallback).
# GEMINI_TIMEOUT_MS=14000

# Optional: max wait for POST /plan-long-term-steps (ms).
# GEMINI_GOAL_TIMEOUT_MS=18000

# Required for account login, /me/* sync, and validating Bearer tokens on the server.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=