# Optional. Default in server.js is 5050 (avoids macOS AirPlay on 5000).
# PORT=5050

# Optional — Google AI Studio API key (put the real value only in backend/.env, never commit it).
# GEMINI_API_KEY=
# Optional model id (default gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
# Optional: max wait for Gemini (ms). On timeout, ORBIT keeps deterministic narrative.
# GEMINI_TIMEOUT_MS=14000
